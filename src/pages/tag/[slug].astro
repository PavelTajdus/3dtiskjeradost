---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import Newsletter from '../../components/Newsletter.astro';
import { SITE_TITLE, SITE_URL } from '../../consts';
import { getPostImage } from '../../utils/getPostImage';
import { createMetaDescription } from '../../utils/seo';
import { slugifyTag } from '../../utils/tags';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
	const tags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))];

	return tags.map((tag) => ({
		params: { slug: slugifyTag(tag) },
		props: { tag },
	}));
}

const { tag } = Astro.props;
const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft && (post.data.tags ?? []).includes(tag))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const countLabel = posts.length === 1 ? 'článek' : posts.length >= 2 && posts.length <= 4 ? 'články' : 'článků';

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Domů', item: SITE_URL },
		{ '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog/` },
		{ '@type': 'ListItem', position: 3, name: tag, item: `${SITE_URL}/tag/${slugifyTag(tag)}/` },
	],
};
---

<!doctype html>
<html lang="cs">
	<head>
		<BaseHead
			title={`${tag} — ${SITE_TITLE}`}
			description={`Všechny články o 3D tisku se štítkem ${tag}. Najdete zde návody, recenze 3D tiskáren, novinky ze světa aditivní výroby, záznamy ze streamů a praktické tipy na jednom místě.`}
			structuredData={breadcrumbSchema}
		/>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-hero-wrap">
				<div class="page-header">
					<nav class="tag-breadcrumbs" aria-label="Drobečková navigace">
						<a href="/">Domů</a>
						<span>/</span>
						<a href="/blog/">Blog</a>
						<span>/</span>
						<span aria-current="page">{tag}</span>
					</nav>
					<h1>Téma: {tag}</h1>
					<p>{posts.length} {countLabel} se štítkem {tag}. Projdi si související návody, recenze a novinky.</p>
				</div>
			</div>

			<div class="container">
				<div class="section-header tag-page-header">
					<h2>Články v tématu</h2>
					<a class="section-link" href="/blog/">Všechny články →</a>
				</div>
				<div class="post-grid">
					{posts.map((post) => {
						const image = getPostImage(post);
						return (
							<article class="post-card">
								<a class="post-card-link" href={`/blog/${post.id}/`}>
									{image && (
										<div class="card-image-wrap">
											<Image src={image} alt={post.data.title} width={560} height={315} format="webp" quality={75} loading="lazy" />
										</div>
									)}
									<div class="meta">
										<span class="tag-label">{tag}</span>
										<span class="sep"></span>
										<FormattedDate date={post.data.pubDate} />
									</div>
									<h3>{post.data.title}</h3>
									{post.data.description && (
										<p class="card-excerpt">{createMetaDescription(post.data.description, 145)}</p>
									)}
								</a>
							</article>
						);
					})}
				</div>
			</div>
		</main>
		<Newsletter />
		<Footer />
	</body>
</html>

<style>
	.tag-breadcrumbs {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		justify-content: center;
		margin-bottom: 18px;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.tag-breadcrumbs a {
		color: var(--text-muted);
	}

	.tag-page-header {
		margin-bottom: 22px;
	}
</style>
