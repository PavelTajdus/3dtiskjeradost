---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPostImage } from '../utils/getPostImage';
import { createMetaDescription } from '../utils/seo';

const allPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = allPosts[0];
const featuredImage = featured ? getPostImage(featured) : undefined;
const posts = allPosts.slice(1, 7);

const beginnerSlugs = [
	'co-je-3d-tisk-kompletni-pruvodce-3d-tiskem',
	'jak-vybrat-3d-tiskarnu',
	'orcaslicer-alternativa-k-prusaslicer-ci-cura',
	'prislusenstvi-k-3d-tiskarne',
];
const beginnerPosts = beginnerSlugs
	.map(slug => allPosts.find(p => p.id === slug))
	.filter(Boolean);
---

<!doctype html>
<html lang="cs">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-badge">Blog • newsletter • 3D tisk</div>
				<h1>3D tisk je <em>radost!</em></h1>
				<p>Tvůj zdroj článků, novinek, recenzí a praktických návodů ze světa 3D tisku.</p>
				<div class="hero-actions">
					<a class="button button-secondary" href="/blog/">Procházet články</a>
					<a class="button button-primary" href="#newsletter">Odebírat newsletter</a>
				</div>
			</section>

			<section class="projects-strip">
				<div class="container projects-grid">
					<a class="project-item" href="#newsletter">
						<strong>Newsletter</strong>
						<span>Pravidelná dávka novinek do e-mailu</span>
					</a>
					<a class="project-item" href="https://www.youtube.com/paveltajdus3d" target="_blank" rel="noopener noreferrer">
						<strong>YouTube</strong>
						<span>Živé streamy a videa o 3D tisku</span>
					</a>
					<a class="project-item" href="https://hotend.cz" target="_blank" rel="noopener noreferrer">
						<strong>Hotend.cz</strong>
						<span>E-shop s materiály pro 3D tisk</span>
					</a>
					<a class="project-item" href="https://printerhive.com" target="_blank" rel="noopener noreferrer">
						<strong>Printerhive.com</strong>
						<span>Vzdálené řízení 3D tiskáren</span>
					</a>
				</div>
			</section>

			<!-- Featured post -->
			{featured && (
				<section class="container featured-post">
					<a class="featured-panel" href={`/blog/${featured.id}/`}>
						{featuredImage && (
							<div class="featured-image-wrap">
								<Image src={featuredImage} alt={featured.data.title} width={1120} height={630} format="webp" quality={80} loading="eager" fetchpriority="high" />
							</div>
						)}
						<div class="featured-copy">
							<div class="meta">
								{featured.data.tags?.[0] && (
									<span class="tag-label">{featured.data.tags[0]}</span>
								)}
								{featured.data.tags?.[0] && <span class="sep"></span>}
								<FormattedDate date={featured.data.pubDate} />
							</div>
							<h2>{featured.data.title}</h2>
							{featured.data.description && (
								<p class="excerpt">{createMetaDescription(featured.data.description, 180)}</p>
							)}
							<span class="read-more">Číst více →</span>
						</div>
					</a>
				</section>
			)}

			<!-- More posts -->
			{posts.length > 0 && (
				<section class="container">
					<div class="section-header">
						<h2>Další články</h2>
						<a class="section-link" href="/blog/">Všechny články →</a>
					</div>
					<div class="post-grid">
						{posts.map(post => (
							<article class="post-card">
								<a href={`/blog/${post.id}/`}>
									{(() => { const img = getPostImage(post); const idx = posts.indexOf(post); return img ? (
										<div class="card-image-wrap">
											<Image src={img} alt={post.data.title} width={560} height={315} format="webp" quality={75} loading={idx < 2 ? "eager" : "lazy"} />
										</div>
									) : null; })()}
									<div class="meta">
										{post.data.tags?.[0] && (
											<span class="tag-label">{post.data.tags[0]}</span>
										)}
										{post.data.tags?.[0] && <span class="sep"></span>}
										<FormattedDate date={post.data.pubDate} />
									</div>
									<h3>{post.data.title}</h3>
									{post.data.description && (
										<p class="card-excerpt">{createMetaDescription(post.data.description, 155)}</p>
									)}
								</a>
							</article>
						))}
					</div>
				</section>
			)}

			<!-- Beginner articles -->
			{beginnerPosts.length > 0 && (
				<section class="container" style="margin-top: 4rem;">
					<div class="section-header">
						<h2>Začínáte s 3D tiskem?</h2>
						<a class="section-link" href="/pro-zacatecniky/">Vše pro začátečníky →</a>
					</div>
					<div class="post-grid">
						{beginnerPosts.map((post, idx) => (
							<article class="post-card">
								<a href={`/blog/${post.id}/`}>
									{(() => { const img = getPostImage(post); return img ? (
										<div class="card-image-wrap">
											<Image src={img} alt={post.data.title} width={560} height={315} format="webp" quality={75} loading="lazy" />
										</div>
									) : null; })()}
									<div class="meta">
										{post.data.tags?.[0] && (
											<span class="tag-label">{post.data.tags[0]}</span>
										)}
									</div>
									<h3>{post.data.title}</h3>
									{post.data.description && (
										<p class="card-excerpt">{createMetaDescription(post.data.description, 155)}</p>
									)}
								</a>
							</article>
						))}
					</div>
				</section>
			)}

		</main>
		<Newsletter />
		<Footer />
	</body>
</html>
