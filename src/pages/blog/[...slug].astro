---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getPostImage } from '../../utils/getPostImage';
import { getReadingTime } from '../../utils/seo';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter(post => !post.data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const ogImage = getPostImage(post);
const allPosts = (await getCollection('blog'))
	.filter((entry) => !entry.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentIndex = allPosts.findIndex((entry) => entry.id === post.id);
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : undefined;
const previousPost = currentIndex >= 0 && currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : undefined;
const currentTags = new Set(post.data.tags ?? []);

const relatedPosts = allPosts
	.filter((entry) => entry.id !== post.id)
	.map((entry) => {
		const sharedTags = (entry.data.tags ?? []).filter((tag) => currentTags.has(tag)).length;
		return {
			entry,
			score: sharedTags * 100 + entry.data.pubDate.valueOf() / 1_000_000_000_000,
		};
	})
	.filter((item) => item.score > 0)
	.sort((a, b) => b.score - a.score)
	.slice(0, 3)
	.map((item) => item.entry);

const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body);
---

<BlogPost
	{...post.data}
	slug={post.id}
	ogImage={ogImage}
	headings={headings}
	readingTime={readingTime}
	relatedPosts={relatedPosts}
	previousPost={previousPost}
	nextPost={nextPost}
>
	<Content />
</BlogPost>
