---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;
const navItems = [
	{ href: '/', label: 'Domů' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/podpora', label: 'Podpora' },
	{ href: '/o-mne', label: 'O mně' },
];
---

<header class="site-header">
	<a href="/" class="site-logo">{SITE_TITLE}</a>
	<nav class="site-nav">
		{navItems.map(item => (
			<a
				href={item.href}
				class:list={['nav-link', { active: pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href)) }]}
			>
				{item.label}
			</a>
		))}
	</nav>
</header>
