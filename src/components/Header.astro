---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;
const navItems = [
	{ href: '/', label: 'Domů' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/podpora', label: 'Podpora' },
	{ href: '/o-mne', label: 'O mně' },
];
---

<header class="site-header">
	<div class="header-inner">
		<a href="/" class="site-logo">{SITE_TITLE}</a>
		<nav class="site-nav">
			{navItems.map(item => (
				<a
					href={item.href}
					class:list={['nav-link', { active: pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href)) }]}
				>
					{item.label}
				</a>
			))}
		</nav>
		<button class="menu-toggle" aria-label="Otevřít menu" id="menuOpen">
			<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
			</svg>
		</button>
	</div>
</header>

<div class="mobile-nav" id="mobileNav">
	<button class="mobile-close" aria-label="Zavřít menu" id="menuClose">
		<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
		</svg>
	</button>
	{navItems.map(item => (
		<a href={item.href}>{item.label}</a>
	))}
</div>

<script>
	const openBtn = document.getElementById('menuOpen');
	const closeBtn = document.getElementById('menuClose');
	const mobileNav = document.getElementById('mobileNav');

	openBtn?.addEventListener('click', () => {
		mobileNav?.classList.add('open');
		document.body.style.overflow = 'hidden';
	});

	closeBtn?.addEventListener('click', () => {
		mobileNav?.classList.remove('open');
		document.body.style.overflow = '';
	});

	mobileNav?.querySelectorAll('a').forEach(link => {
		link.addEventListener('click', () => {
			mobileNav?.classList.remove('open');
			document.body.style.overflow = '';
		});
	});
</script>
