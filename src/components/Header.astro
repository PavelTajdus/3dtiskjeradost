---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;
const navItems = [
	{ href: '/', label: 'Domů' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/podpora', label: 'Podpora' },
	{ href: '/o-mne', label: 'O mně' },
];
---

<header class="site-header">
	<a href="/" class="site-logo">{SITE_TITLE}</a>
	<nav class="site-nav">
		{navItems.map(item => (
			<a
				href={item.href}
				class:list={['nav-link', { active: pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href)) }]}
			>
				{item.label}
			</a>
		))}
	</nav>
</header>

<style is:global>
	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: nowrap;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 24px;
		height: 64px;
		border-bottom: 1px solid var(--border);
	}
	.site-logo {
		font-family: var(--font-display);
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--text);
		text-decoration: none;
		white-space: nowrap;
		flex-shrink: 0;
	}
	.site-logo:hover {
		text-decoration: none;
	}
	.site-nav {
		display: flex;
		gap: 32px;
		flex-shrink: 0;
	}
	.nav-link {
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: none;
		letter-spacing: 0.02em;
		white-space: nowrap;
	}
	.nav-link:hover,
	.nav-link.active {
		color: var(--text);
		text-decoration: none;
	}
	@media (max-width: 600px) {
		.site-nav { gap: 16px; }
		.nav-link { font-size: 0.8rem; }
		.site-logo { font-size: 1.05rem; }
	}
</style>
