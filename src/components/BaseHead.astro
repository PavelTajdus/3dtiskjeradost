---
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	publishedDate?: Date;
	modifiedDate?: Date;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
	title,
	description = SITE_DESCRIPTION,
	image = '/og-default.jpg',
	type = 'website',
	publishedDate,
	modifiedDate,
} = Astro.props;

const metaTitle = title.includes(SITE_TITLE) ? title : `${title} — ${SITE_TITLE}`;
const ogImageURL = image.startsWith('http') ? image : new URL(image, Astro.site).toString();

const jsonLd = type === 'article'
	? {
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: title,
		description,
		image: ogImageURL,
		url: canonicalURL.toString(),
		datePublished: publishedDate?.toISOString(),
		dateModified: modifiedDate?.toISOString() || publishedDate?.toISOString(),
		author: {
			'@type': 'Person',
			name: 'Pavel Tajduš',
			url: 'https://3dtiskjeradost.cz/o-mne/',
		},
		publisher: {
			'@type': 'Organization',
			name: SITE_TITLE,
			url: 'https://3dtiskjeradost.cz',
		},
	}
	: {
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_TITLE,
		description,
		url: 'https://3dtiskjeradost.cz',
		author: {
			'@type': 'Person',
			name: 'Pavel Tajduš',
		},
	};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={metaTitle} href={new URL('rss.xml', Astro.site)} />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#215DEE" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:ital,opsz,wght@0,14..32,400..600;1,14..32,400..600&display=swap" rel="stylesheet" />

<link rel="canonical" href={canonicalURL} />

<title>{metaTitle}</title>
<meta name="title" content={metaTitle} />
<meta name="description" content={description} />
<meta name="author" content="Pavel Tajduš" />

<meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={metaTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="cs_CZ" />
{publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}
{modifiedDate && <meta property="article:modified_time" content={modifiedDate.toISOString()} />}

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={metaTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageURL} />
<meta property="twitter:image:alt" content={title} />
<meta property="twitter:site" content="@PavelTajdus" />
<meta property="twitter:creator" content="@PavelTajdus" />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
