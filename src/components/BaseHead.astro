---
import {
	AUTHOR_NAME,
	AUTHOR_URL,
	AUTHOR_X_HANDLE,
	DEFAULT_OG_IMAGE,
	SITE_DESCRIPTION,
	SITE_TITLE,
	SITE_URL,
	SOCIAL_LINKS,
} from '../consts';
import { absoluteUrl, createMetaDescription } from '../utils/seo';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	publishedDate?: Date;
	modifiedDate?: Date;
	tags?: string[];
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE_URL);
const {
	title,
	description = SITE_DESCRIPTION,
	image = DEFAULT_OG_IMAGE,
	type = 'website',
	publishedDate,
	modifiedDate,
	tags = [],
	structuredData,
} = Astro.props;

const fullTitle = `${title} — ${SITE_TITLE}`;
const metaTitle = title.includes(SITE_TITLE) ? title : fullTitle.length <= 60 ? fullTitle : title;
const metaDescription = createMetaDescription(description);
const ogImageURL = absoluteUrl(image);
const keywords = tags.length > 0 ? tags.join(', ') : undefined;
const pageType = Astro.url.pathname === '/blog/' ? 'CollectionPage' : 'WebPage';

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: SITE_TITLE,
	url: SITE_URL,
	logo: absoluteUrl('/favicon.svg'),
	sameAs: SOCIAL_LINKS,
	founder: {
		'@type': 'Person',
		name: AUTHOR_NAME,
		url: AUTHOR_URL,
	},
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	description: SITE_DESCRIPTION,
	url: SITE_URL,
	inLanguage: 'cs-CZ',
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		url: SITE_URL,
	},
	potentialAction: {
		'@type': 'SearchAction',
		target: `${SITE_URL}/blog/?q={search_term_string}`,
		'query-input': 'required name=search_term_string',
	},
};

const pageSchema = type === 'article'
	? {
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: title,
		description: metaDescription,
		image: [ogImageURL],
		url: canonicalURL.toString(),
		mainEntityOfPage: canonicalURL.toString(),
		datePublished: publishedDate?.toISOString(),
		dateModified: modifiedDate?.toISOString() || publishedDate?.toISOString(),
		inLanguage: 'cs-CZ',
		keywords,
		articleSection: tags[0],
		author: {
			'@type': 'Person',
			name: AUTHOR_NAME,
			url: AUTHOR_URL,
		},
		publisher: {
			'@type': 'Organization',
			name: SITE_TITLE,
			url: SITE_URL,
			logo: {
				'@type': 'ImageObject',
				url: absoluteUrl('/favicon.svg'),
			},
		},
	}
	: {
		'@context': 'https://schema.org',
		'@type': pageType,
		name: metaTitle,
		description: metaDescription,
		url: canonicalURL.toString(),
		inLanguage: 'cs-CZ',
		isPartOf: {
			'@type': 'WebSite',
			name: SITE_TITLE,
			url: SITE_URL,
		},
	};

const extraStructuredData = Array.isArray(structuredData)
	? structuredData
	: structuredData
		? [structuredData]
		: [];

const jsonLd = [organizationSchema, websiteSchema, pageSchema, ...extraStructuredData];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="theme-color" content="#215DEE" />
<meta name="author" content={AUTHOR_NAME} />
{keywords && <meta name="keywords" content={keywords} />}

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', Astro.site ?? SITE_URL)} />
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<title>{metaTitle}</title>
<meta name="title" content={metaTitle} />
<meta name="description" content={metaDescription} />

<meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={metaTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="cs_CZ" />
{publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}
{(modifiedDate || publishedDate) && <meta property="article:modified_time" content={(modifiedDate ?? publishedDate)?.toISOString()} />}
{tags[0] && <meta property="article:section" content={tags[0]} />}
{tags.map((tag) => <meta property="article:tag" content={tag} />)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={metaTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:image:alt" content={title} />
<meta name="twitter:site" content={AUTHOR_X_HANDLE} />
<meta name="twitter:creator" content={AUTHOR_X_HANDLE} />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<script src="https://analytics.ahrefs.com/analytics.js" data-key="YAeq/3MtsVuct1mQsQkslg" async></script>
