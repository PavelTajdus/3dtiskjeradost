---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE_TITLE, SITE_URL } from '../consts';
import { getPostImage } from '../utils/getPostImage';
import { getTagHref } from '../utils/tags';

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	slug: string;
	ogImage?: string;
	headings?: Heading[];
	readingTime?: number;
	relatedPosts?: CollectionEntry<'blog'>[];
	previousPost?: CollectionEntry<'blog'>;
	nextPost?: CollectionEntry<'blog'>;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	slug,
	ogImage,
	headings = [],
	readingTime,
	relatedPosts = [],
	previousPost,
	nextPost,
} = Astro.props;

const tableOfContents = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const articleUrl = `${SITE_URL}/blog/${slug}/`;
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Domů',
			item: SITE_URL,
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Blog',
			item: `${SITE_URL}/blog/`,
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: title,
			item: articleUrl,
		},
	],
};
---

<html lang="cs">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={ogImage ?? heroImage}
			type="article"
			publishedDate={pubDate}
			modifiedDate={updatedDate}
			tags={tags}
			structuredData={breadcrumbSchema}
		/>
	</head>
	<body>
		<Header />
		<main>
			<div class="article-header-wrap">
				<div class="article-header">
					<nav class="article-breadcrumbs" aria-label="Drobečková navigace">
						<a href="/">Domů</a>
						<span>/</span>
						<a href="/blog">Blog</a>
						<span>/</span>
						<span aria-current="page">{title}</span>
					</nav>
					<h1>{title}</h1>
					<div class="article-meta-row">
						<div class="meta">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<><span class="sep"></span><span>Aktualizováno <FormattedDate date={updatedDate} /></span></>
							)}
							{readingTime && (
								<><span class="sep"></span><span>{readingTime} min čtení</span></>
							)}
						</div>
						{tags.length > 0 && (
							<div class="article-tags" aria-label="Tagy článku">
								{tags.map(tag => (
									<a class="tag-label tag-link" href={getTagHref(tag)}>
										{tag}
									</a>
								))}
							</div>
						)}
					</div>
				</div>
			</div>

			<article class="container article-shell">
				<div class="article-main">
					{heroImage && (
						<Image class="hero-image" src={heroImage} alt={title} width={960} height={540} format="webp" quality={80} loading="eager" fetchpriority="high" />
					)}

					<div class="prose">
						<slot />
					</div>

					{(previousPost || nextPost) && (
						<nav class="article-pager" aria-label="Sousední články">
							{nextPost ? (
								<a class="article-pager-link" href={`/blog/${nextPost.id}/`}>
									<span class="article-pager-label">← Novější článek</span>
									<strong>{nextPost.data.title}</strong>
								</a>
							) : <span />}
							{previousPost ? (
								<a class="article-pager-link article-pager-link-right" href={`/blog/${previousPost.id}/`}>
									<span class="article-pager-label">Starší článek →</span>
									<strong>{previousPost.data.title}</strong>
								</a>
							) : <span />}
						</nav>
					)}

					{relatedPosts.length > 0 && (
						<section class="related-posts" aria-labelledby="related-posts-title">
							<div class="section-header related-posts-header">
								<h2 id="related-posts-title">Související články</h2>
								<a class="section-link" href="/blog">Všechny články →</a>
							</div>
							<div class="related-posts-grid">
								{relatedPosts.map((post) => {
									const image = getPostImage(post);
									return (
										<article class="related-post-card">
											<a href={`/blog/${post.id}/`}>
												{image && (
													<div class="related-post-image-wrap">
														<Image src={image} alt={post.data.title} width={480} height={270} format="webp" quality={74} loading="lazy" />
													</div>
												)}
												<div class="meta">
													{post.data.tags?.[0] && <span class="tag-label">{post.data.tags[0]}</span>}
													{post.data.tags?.[0] && <span class="sep"></span>}
													<FormattedDate date={post.data.pubDate} />
												</div>
												<h3>{post.data.title}</h3>
											</a>
										</article>
									);
								})}
							</div>
						</section>
					)}

					<div class="back-link">
						<a href="/blog">← Zpět na články</a>
					</div>
				</div>

				{tableOfContents.length > 1 && (
					<aside class="article-sidebar" aria-labelledby="toc-title">
						<div class="toc-card">
							<h2 id="toc-title">Obsah článku</h2>
							<nav aria-label="Obsah článku">
								<ol class="toc-list">
									{tableOfContents.map((heading) => (
										<li class:list={{ 'toc-subitem': heading.depth === 3 }}>
											<a href={`#${heading.slug}`}>{heading.text}</a>
										</li>
									))}
								</ol>
							</nav>
						</div>
					</aside>
				)}
			</article>
		</main>
		<Newsletter
			heading="Líbí se ti podobné články?"
			text="Přihlas se k newsletteru a pošlu ti nové články, novinky a zajímavosti ze světa 3D tisku přímo do e-mailu."
		/>
		<Footer />
	</body>
</html>

<style>
	.article-shell {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: 40px;
		align-items: start;
	}

	.article-main {
		min-width: 0;
	}

	.article-breadcrumbs {
		display: flex;
		align-items: center;
		gap: 10px;
		flex-wrap: wrap;
		margin-bottom: 20px;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.article-breadcrumbs a {
		color: var(--text-muted);
	}

	.article-breadcrumbs a:hover {
		color: var(--accent);
	}

	.article-meta-row {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.article-tags {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
	}

	.article-sidebar {
		position: sticky;
		top: 96px;
	}

	.toc-card {
		padding: 22px;
		border: 1px solid var(--border);
		border-radius: 18px;
		background: var(--bg-soft);
	}

	.toc-card h2 {
		font-size: 1.1rem;
		margin-bottom: 14px;
	}

	.toc-list {
		list-style: none;
		display: grid;
		gap: 10px;
		padding: 0;
		margin: 0;
	}

	.toc-list a {
		color: var(--text-secondary);
		line-height: 1.45;
	}

	.toc-list a:hover {
		color: var(--accent);
	}

	.toc-subitem {
		padding-left: 16px;
		font-size: 0.96rem;
	}

	.related-posts {
		margin-top: 56px;
	}

	.related-posts-header {
		margin-bottom: 22px;
	}

	.related-posts-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
	}

	.related-post-card {
		border: 1px solid var(--border);
		border-radius: 18px;
		overflow: hidden;
		background: #fff;
	}

	.related-post-card a {
		display: block;
		padding: 16px;
		height: 100%;
		color: inherit;
	}

	.related-post-card a:hover {
		color: inherit;
	}

	.related-post-card h3 {
		font-size: 1.05rem;
		margin-top: 12px;
	}

	.related-post-image-wrap {
		margin: -16px -16px 14px;
	}

	.article-pager {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 16px;
		margin-top: 40px;
	}

	.article-pager-link {
		display: grid;
		gap: 6px;
		padding: 18px;
		border: 1px solid var(--border);
		border-radius: 16px;
		background: var(--bg-soft);
		color: inherit;
	}

	.article-pager-link:hover {
		color: inherit;
		border-color: rgba(33, 93, 238, 0.3);
	}

	.article-pager-link-right {
		text-align: right;
	}

	.article-pager-label {
		font-size: 0.82rem;
		color: var(--text-muted);
	}

	@media (max-width: 1024px) {
		.article-shell {
			grid-template-columns: minmax(0, 1fr);
		}

		.article-sidebar {
			position: static;
			order: -1;
		}
	}

	@media (max-width: 768px) {
		.related-posts-grid,
		.article-pager {
			grid-template-columns: 1fr;
		}
	}
</style>
